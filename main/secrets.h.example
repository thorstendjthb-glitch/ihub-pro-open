// secrets.h.example — OPTIONAL build-time credentials.
//
// You do NOT need this file. The iHub-Pro is fully configurable at runtime
// (Wi-Fi captive portal + web UI). This is only a convenience for developers
// who want to flash several devices with Wi-Fi already baked in.
//
// HOW TO USE:
//   1. Copy this file to "secrets.h" (same folder).
//   2. Fill in the values you want.
//   3. Build & flash. `secrets.h` is git-ignored and overrides app_config.h.
//
// NEVER commit your real secrets.h to a public repository.
#pragma once

// Wi-Fi the device should join on boot (leave undefined to use the setup portal).
// #define CFG_WIFI_SSID       "MyNetwork"
// #define CFG_WIFI_PASSWORD   "MyWifiPassword"

// MQTT broker for Home Assistant (leave undefined to configure later in the UI).
// #define CFG_MQTT_URI        "mqtt://homeassistant.local:1883"
// #define CFG_MQTT_USER       "ihub"
// #define CFG_MQTT_PASS       "MyMqttPassword"
